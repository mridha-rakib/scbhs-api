{
  "compilerOptions": {
    "target": "esnext",
    "baseUrl": "./src",
    "rootDir": "./",
    "module": "commonjs",
    "paths": {
      "@/*": ["*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "outDir": "dist",
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["./*.js", "src/**/*.ts", "test/**/*.ts"]
}
